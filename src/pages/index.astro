---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mapa de Calor DIU - Colombia</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0a0f1a] text-white min-h-screen font-['Outfit']">
  <header class="bg-gradient-to-r from-[#0d1525] via-[#131b2e] to-[#0d1525] border-b border-[#1e293b] px-6 py-4">
    <div class="max-w-[1920px] mx-auto flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div>
        <h1 class="text-2xl lg:text-3xl font-bold bg-gradient-to-r from-emerald-400 via-cyan-400 to-blue-400 bg-clip-text text-transparent">
          Mapa de Cumplimiento DIU
        </h1>
        <p class="text-slate-400 text-sm mt-1">Dirección de Instrumentos y Usuarios - Colombia</p>
      </div>
      <div class="flex flex-wrap gap-4 items-center">
        <div class="bg-[#131b2e] border border-[#1e293b] rounded-lg px-4 py-2 flex items-center gap-3">
          <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
          <span class="text-xs text-slate-400">Periodo Tarifario</span>
          <span class="text-sm font-semibold text-emerald-400">Año 5+</span>
        </div>
        <div class="bg-[#131b2e] border border-[#1e293b] rounded-lg px-4 py-2 text-xs">
          <span class="text-slate-500">Factor aplicable:</span>
          <span class="text-cyan-400 font-semibold ml-1">80%</span>
        </div>
      </div>
    </div>
  </header>

  <div class="flex flex-col lg:flex-row min-h-[calc(100vh-80px)]">
    <div class="relative w-full lg:w-2/3 h-[55vh] lg:h-auto order-1 lg:order-1">
      <div id="map" class="w-full h-full grayscale-[0.3]"></div>
      <div class="absolute top-4 left-4 z-[1000] bg-[#0d1525]/90 backdrop-blur-sm border border-[#1e293b] rounded-lg p-3">
        <div class="flex items-center gap-2 text-xs text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span>Después del año 5: DIUG = 80% × DIUG estimado</span>
        </div>
      </div>
    </div>

    <div class="w-full lg:w-1/3 bg-[#0d1525] border-l border-[#1e293b] order-2 lg:order-2 flex flex-col">
      <div class="p-6 border-b border-[#1e293b]">
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-gradient-to-br from-[#131b2e] to-[#1a2236] border border-[#1e293b] rounded-xl p-4">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Total Usuarios</p>
            <p id="stat-total" class="text-2xl font-bold text-white font-['JetBrains_Mono']">-</p>
          </div>
          <div class="bg-gradient-to-br from-[#131b2e] to-[#1a2236] border border-[#1e293b] rounded-xl p-4">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Promedio DIU</p>
            <p id="stat-promedio" class="text-2xl font-bold text-emerald-400 font-['JetBrains_Mono']">-</p>
          </div>
          <div class="bg-gradient-to-br from-[#131b2e] to-[#1a2236] border border-[#1e293b] rounded-xl p-4">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Municipios</p>
            <p id="stat-municipios" class="text-2xl font-bold text-cyan-400 font-['JetBrains_Mono']">-</p>
          </div>
          <div class="bg-gradient-to-br from-[#131b2e] to-[#1a2236] border border-[#1e293b] rounded-xl p-4">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Cumplimiento</p>
            <p id="stat-cumplimiento" class="text-2xl font-bold text-amber-400 font-['JetBrains_Mono']">-</p>
          </div>
        </div>
      </div>

      <div class="p-6 flex-1 overflow-hidden flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider">Leyenda DIU</h2>
        </div>
        <div class="space-y-2 mb-6">
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
            <div class="w-4 h-4 rounded shadow-lg shadow-emerald-500/30" style="background: linear-gradient(135deg, #059669, #10b981);"></div>
            <span class="text-sm text-slate-300">90-100% <span class="text-emerald-400">Excelente</span></span>
          </div>
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
            <div class="w-4 h-4 rounded shadow-lg shadow-green-500/30" style="background: linear-gradient(135deg, #4ade80, #22c55e);"></div>
            <span class="text-sm text-slate-300">70-89% <span class="text-green-400">Bueno</span></span>
          </div>
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
            <div class="w-4 h-4 rounded shadow-lg shadow-yellow-500/30" style="background: linear-gradient(135deg, #facc15, #eab308);"></div>
            <span class="text-sm text-slate-300">50-69% <span class="text-yellow-400">Medio</span></span>
          </div>
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
            <div class="w-4 h-4 rounded shadow-lg shadow-orange-500/30" style="background: linear-gradient(135deg, #fb923c, #f97316);"></div>
            <span class="text-sm text-slate-300">30-49% <span class="text-orange-400">Bajo</span></span>
          </div>
          <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
            <div class="w-4 h-4 rounded shadow-lg shadow-red-500/30" style="background: linear-gradient(135deg, #ef4444, #dc2626);"></div>
            <span class="text-sm text-slate-300">0-29% <span class="text-red-400">Crítico</span></span>
          </div>
        </div>

        <div class="mt-auto">
          <h3 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-3">Municipios</h3>
          <div id="lista-municipios" class="space-y-1 max-h-[200px] overflow-y-auto pr-2 scrollbar-thin">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="tooltip" class="fixed hidden z-[9999] bg-[#0d1525]/95 backdrop-blur-md border border-[#1e293b] rounded-xl p-4 shadow-2xl shadow-black/50 min-w-[220px]">
    <h4 id="tooltip-nombre" class="font-bold text-lg text-emerald-400 mb-2"></h4>
    <div class="space-y-1.5 text-sm">
      <div class="flex justify-between">
        <span class="text-slate-500">Total Usuarios</span>
        <span id="tooltip-total" class="font-semibold font-['JetBrains_Mono']"></span>
      </div>
      <div class="flex justify-between">
        <span class="text-slate-500">Cumplen DIU</span>
        <span id="tooltip-diu" class="font-semibold font-['JetBrains_Mono']"></span>
      </div>
      <div class="flex justify-between">
        <span class="text-slate-500">% FIU</span>
        <span id="tooltip-fiu" class="font-semibold font-['JetBrains_Mono'] text-cyan-400"></span>
      </div>
      <div class="flex justify-between border-t border-[#1e293b] pt-2 mt-2">
        <span class="text-slate-400 font-medium">% DIU</span>
        <span id="tooltip-pdiu" class="font-bold text-xl font-['JetBrains_Mono']"></span>
      </div>
    </div>
  </div>

  <style is:global>
    .scrollbar-thin::-webkit-scrollbar { width: 4px; }
    .scrollbar-thin::-webkit-scrollbar-track { background: #131b2e; }
    .scrollbar-thin::-webkit-scrollbar-thumb { background: #334155; border-radius: 2px; }
    .leaflet-container { background: #0a0f1a; }
    .leaflet-control-attribution { background: rgba(13, 21, 37, 0.8) !important; color: #64748b !important; }
    .leaflet-control-zoom { border: none !important; }
    .leaflet-control-zoom a { background: #131b2e !important; color: #94a3b8 !important; border: 1px solid #1e293b !important; }
    .leaflet-control-zoom a:hover { background: #1a2236 !important; }
    .leaflet-popup-content-wrapper { background: #0d1525 !important; border: 1px solid #1e293b !important; border-radius: 12px !important; color: #e2e8f0 !important; }
    .leaflet-popup-tip { background: #0d1525 !important; }
  </style>

  <script>
    const colorScale = (porcentaje) => {
      if (porcentaje >= 90) return 'linear-gradient(135deg, #059669, #10b981)';
      if (porcentaje >= 70) return 'linear-gradient(135deg, #4ade80, #22c55e)';
      if (porcentaje >= 50) return 'linear-gradient(135deg, #facc15, #eab308)';
      if (porcentaje >= 30) return 'linear-gradient(135deg, #fb923c, #f97316)';
      return 'linear-gradient(135deg, #ef4444, #dc2626)';
    };

    const getColor = (porcentaje) => {
      if (porcentaje >= 90) return '#10b981';
      if (porcentaje >= 70) return '#22c55e';
      if (porcentaje >= 50) return '#eab308';
      if (porcentaje >= 30) return '#f97316';
      return '#dc2626';
    };

    let map;
    let geoJsonLayer;
    let usuariosData = [];

    async function initMap() {
      map = L.map('map', {
        center: [4.5, -72.5],
        zoom: 6,
        zoomControl: true
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '',
        maxZoom: 19
      }).addTo(map);

      const response = await fetch('/colombia-municipios.geojson');
      const geoData = await response.json();

      const usuariosRes = await fetch('/api/usuarios.json');
      usuariosData = await usuariosRes.json();

      let totalUsuarios = 0;
      let sumaDiu = 0;

      geoData.features.forEach(feature => {
        const nombreMpio = feature.properties.MPIO_CNMBR.toUpperCase()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        
        const usuario = usuariosData.find(u => {
          const nombreDB = u.municipio.toUpperCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          return nombreDB === nombreMpio || 
                 nombreDB.includes(nombreMpio) || 
                 nombreMpio.includes(nombreDB);
        });

        if (usuario) {
          feature.properties.usuario = usuario;
          totalUsuarios += usuario.total_usuarios;
          sumaDiu += usuario.porcentaje_diu;
        }
      });

      const promedio = sumaDiu / usuariosData.length;
      document.getElementById('stat-total').textContent = totalUsuarios.toLocaleString();
      document.getElementById('stat-promedio').textContent = promedio.toFixed(1) + '%';
      document.getElementById('stat-municipios').textContent = usuariosData.length;
      document.getElementById('stat-cumplimiento').textContent = promedio >= 80 ? 'Bueno' : promedio >= 50 ? 'Regular' : 'Bajo';

      geoJsonLayer = L.geoJSON(geoData, {
        style: (feature) => {
          const usuario = feature.properties.usuario;
          const color = usuario ? getColor(usuario.porcentaje_diu) : '#1e293b';
          const fillOpacity = usuario ? 0.75 : 0.15;
          return {
            fillColor: color,
            weight: 1,
            opacity: 1,
            color: '#0f172a',
            fillOpacity: fillOpacity
          };
        },
        onEachFeature: (feature, layer) => {
          const usuario = feature.properties.usuario;
          if (usuario) {
            layer.bindTooltip(
              `<strong>${feature.properties.MPIO_CNMBR}</strong><br><span style="color: ${getColor(usuario.porcentaje_diu)}">% DIU: ${usuario.porcentaje_diu}%</span>`,
              { 
                className: 'custom-tooltip',
                direction: 'top',
                offset: [0, -10]
              }
            );
            
            layer.on('mouseover', (e) => {
              layer.setStyle({ weight: 2, fillOpacity: 0.9 });
              const tooltip = document.getElementById('tooltip');
              const bounds = e.containerPoint;
              tooltip.style.left = bounds.x + 15 + 'px';
              tooltip.style.top = bounds.y - 50 + 'px';
              tooltip.classList.remove('hidden');
              document.getElementById('tooltip-nombre').textContent = feature.properties.MPIO_CNMBR;
              document.getElementById('tooltip-total').textContent = usuario.total_usuarios.toLocaleString();
              document.getElementById('tooltip-diu').textContent = usuario.cumplen_diu.toLocaleString();
              document.getElementById('tooltip-fiu').textContent = usuario.porcentaje_fiu + '%';
              document.getElementById('tooltip-pdiu').textContent = usuario.porcentaje_diu + '%';
              document.getElementById('tooltip-pdiu').style.color = getColor(usuario.porcentaje_diu);
            });

            layer.on('mouseout', () => {
              layer.setStyle({ weight: 1, fillOpacity: 0.75 });
              document.getElementById('tooltip').classList.add('hidden');
            });
          }
        }
      }).addTo(map);

      const listaDiv = document.getElementById('lista-municipios');
      usuariosData.sort((a, b) => b.porcentaje_diu - a.porcentaje_diu).forEach(u => {
        const div = document.createElement('div');
        div.className = 'flex justify-between items-center p-2 rounded-lg hover:bg-[#131b2e] cursor-pointer transition-all border border-transparent hover:border-[#1e293b]';
        div.innerHTML = `
          <span class="text-sm text-slate-300">${u.municipio}</span>
          <span class="font-bold font-['JetBrains_Mono'] text-sm" style="color: ${getColor(u.porcentaje_diu)}">${u.porcentaje_diu}%</span>
        `;
        div.onclick = () => {
          const feature = geoData.features.find(f => {
            const nombreMpio = f.properties.MPIO_CNMBR.toUpperCase()
              .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            const nombreDB = u.municipio.toUpperCase()
              .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            return nombreDB === nombreMpio || nombreDB.includes(nombreMpio) || nombreMpio.includes(nombreDB);
          });
          if (feature) {
            const layer = geoJsonLayer.getLayers().find(l => l.feature === feature);
            if (layer) {
              map.fitBounds(layer.getBounds(), { padding: [50, 50] });
              map.setZoom(9);
            }
          }
        };
        listaDiv.appendChild(div);
      });
    }

    initMap();
  </script>
</body>
</html>