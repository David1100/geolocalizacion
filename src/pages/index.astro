---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mapa de Calor DIU - Pereira-Cartago</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0a0f1a] text-white min-h-screen font-['Outfit']">
  <header class="relative overflow-hidden bg-gradient-to-r from-[#0d1525] via-[#131b2e] to-[#0d1525] border-b border-[#1e293b]">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-emerald-500/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-cyan-500/20 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-[1920px] mx-auto px-6 py-6">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div class="flex items-center gap-6">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-cyan-500 flex items-center justify-center shadow-lg shadow-emerald-500/30">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-1">
              <select id="select-empresa" class="bg-[#131b2e] border border-[#1e293b] rounded-lg px-3 py-1 text-xs font-semibold text-emerald-400 cursor-pointer hover:border-emerald-500/50 transition-all" onchange="cambiarEmpresa(this.value)">
                <option value="PEREIRA-CARTAGO">PEREIRA-CARTAGO</option>
                <option value="PEREIRA-EEPD">PEREIRA-EEPD</option>
                <option value="EMCALI">EMCALI</option>
                <option value="CETSA">CETSA</option>
              </select>
            </div>
            <h1 id="titulo-mapa" class="text-3xl lg:text-4xl font-extrabold bg-gradient-to-r from-white via-emerald-200 to-cyan-200 bg-clip-text text-transparent">
              Mapa de Cumplimiento DIU
            </h1>
            <p class="text-slate-400 text-sm mt-1">Dirección de Instrumentos y Usuarios</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-3 items-center">
          <div class="bg-[#131b2e]/80 backdrop-blur border border-[#1e293b] rounded-xl px-5 py-3">
            <div class="flex items-center gap-2 mb-1">
              <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
              <span class="text-xs text-slate-400 uppercase tracking-wider">Periodo</span>
            </div>
            <span class="text-lg font-bold text-emerald-400 font-['JetBrains_Mono']">Año 5+</span>
          </div>
          <div class="bg-[#131b2e]/80 backdrop-blur border border-[#1e293b] rounded-xl px-5 py-3">
            <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Factor</div>
            <span class="text-lg font-bold text-cyan-400 font-['JetBrains_Mono']">80%</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="flex flex-col lg:flex-row min-h-[calc(100vh-120px)]">
    <div class="relative w-full lg:w-2/3 h-[50vh] lg:h-auto order-1 lg:order-1">
      <div id="map" class="w-full h-full"></div>
      <div class="absolute bottom-4 left-4 z-[1000] bg-[#0d1525]/90 backdrop-blur-sm border border-[#1e293b] rounded-xl p-4 max-w-xs">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span class="text-xs text-slate-400">Numeral 5.2.5</span>
        </div>
        <p class="text-xs text-slate-500 leading-relaxed">Después del año 5: DIUG = 80% × DIUG estimado</p>
      </div>
    </div>

    <div class="w-full lg:w-1/3 bg-[#0d1525] border-l border-[#1e293b] order-2 lg:order-2 flex flex-col h-screen overflow-hidden">
      <div class="p-4 border-b border-[#1e293b] bg-gradient-to-r from-[#131b2e] to-[#0d1525]">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-white flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
            Estadísticas
          </h2>
          <div class="flex bg-[#0d1525] rounded-lg p-1 border border-[#1e293b]">
            <button id="btn-diu" class="px-3 py-1.5 rounded-md text-xs font-semibold transition-all bg-emerald-500/20 text-emerald-400" onclick="cambiarIndicador('DIU')">
              DIU
            </button>
            <button id="btn-fiu" class="px-3 py-1.5 rounded-md text-xs font-semibold transition-all text-slate-400 hover:text-white" onclick="cambiarIndicador('FIU')">
              FIU
            </button>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-[#0d1525] border border-[#1e293b] rounded-xl p-3 hover:border-emerald-500/50 transition-all">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Total Usuarios</p>
            <p id="stat-total" class="text-lg font-bold text-white font-['JetBrains_Mono']">-</p>
          </div>
          <div class="bg-[#0d1525] border border-[#1e293b] rounded-xl p-3 hover:border-emerald-500/50 transition-all">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Promedio <span id="label-indicador">DIU</span></p>
            <p id="stat-promedio" class="text-lg font-bold text-emerald-400 font-['JetBrains_Mono']">-</p>
          </div>
          <div class="bg-[#0d1525] border border-[#1e293b] rounded-xl p-4 hover:border-emerald-500/50 transition-all">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Municipios</p>
            <p id="stat-municipios" class="text-xl font-bold text-cyan-400 font-['JetBrains_Mono']">-</p>
          </div>
          <div class="bg-[#0d1525] border border-[#1e293b] rounded-xl p-4 hover:border-emerald-500/50 transition-all">
            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Estado</p>
            <p id="stat-cumplimiento" class="text-xl font-bold text-amber-400 font-['JetBrains_Mono']">-</p>
          </div>
        </div>
      </div>

      <div class="p-4 flex-1 overflow-hidden flex flex-col">
        <div class="flex gap-2 mb-4">
          <button id="btn-leyenda" class="flex-1 py-2 px-4 rounded-lg text-sm font-semibold transition-all bg-emerald-500/20 text-emerald-400 border border-emerald-500/30" onclick="showPanel('leyenda')">
            Leyenda
          </button>
          <button id="btn-municipios" class="flex-1 py-2 px-4 rounded-lg text-sm font-semibold transition-all bg-[#131b2e] text-slate-400 border border-[#1e293b]" onclick="showPanel('municipios')">
            Municipios
          </button>
        </div>

        <div id="panel-leyenda" class="flex-1 overflow-y-auto scrollbar-thin">
          <div class="space-y-2">
            <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
              <div class="w-8 h-8 rounded-lg shadow-lg" style="background: linear-gradient(135deg, #059669, #10b981); box-shadow: 0 0 20px rgba(16, 185, 129, 0.4);"></div>
              <span class="text-sm text-slate-300">90-100% <span class="text-emerald-400 font-medium">Excelente</span></span>
            </div>
            <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
              <div class="w-8 h-8 rounded-lg shadow-lg" style="background: linear-gradient(135deg, #4ade80, #22c55e); box-shadow: 0 0 15px rgba(34, 197, 94, 0.3);"></div>
              <span class="text-sm text-slate-300">70-89% <span class="text-green-400 font-medium">Bueno</span></span>
            </div>
            <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
              <div class="w-8 h-8 rounded-lg shadow-lg" style="background: linear-gradient(135deg, #facc15, #eab308); box-shadow: 0 0 15px rgba(234, 179, 8, 0.3);"></div>
              <span class="text-sm text-slate-300">50-69% <span class="text-yellow-400 font-medium">Medio</span></span>
            </div>
            <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
              <div class="w-8 h-8 rounded-lg shadow-lg" style="background: linear-gradient(135deg, #fb923c, #f97316); box-shadow: 0 0 15px rgba(249, 115, 22, 0.3);"></div>
              <span class="text-sm text-slate-300">30-49% <span class="text-orange-400 font-medium">Bajo</span></span>
            </div>
            <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-[#131b2e] transition-colors">
              <div class="w-8 h-8 rounded-lg shadow-lg" style="background: linear-gradient(135deg, #ef4444, #dc2626); box-shadow: 0 0 15px rgba(220, 38, 38, 0.3);"></div>
              <span class="text-sm text-slate-300">0-29% <span class="text-red-400 font-medium">Crítico</span></span>
            </div>
          </div>
        </div>

        <div id="panel-municipios" class="hidden flex-1 overflow-y-auto scrollbar-thin">
          <div id="lista-municipios" class="space-y-1">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="tooltip" class="fixed hidden z-[9999] bg-[#0d1525]/95 backdrop-blur-md border border-[#1e293b] rounded-xl p-4 shadow-2xl shadow-black/50 min-w-[240px]" style="box-shadow: 0 0 40px rgba(16, 185, 129, 0.2);">
    <div class="flex items-center gap-2 mb-3 pb-2 border-b border-[#1e293b]">
      <div class="w-3 h-3 rounded-full bg-emerald-400"></div>
      <h4 id="tooltip-nombre" class="font-bold text-lg text-white"></h4>
    </div>
    <div class="space-y-2 text-sm">
      <div class="flex justify-between items-center bg-[#131b2e] rounded-lg px-3 py-2">
        <span class="text-slate-500">Total Usuarios</span>
        <span id="tooltip-total" class="font-semibold font-['JetBrains_Mono'] text-white"></span>
      </div>
      <div class="flex justify-between items-center bg-[#131b2e] rounded-lg px-3 py-2">
        <span class="text-slate-500">Cumplen DIU</span>
        <span id="tooltip-diu" class="font-semibold font-['JetBrains_Mono'] text-white"></span>
      </div>
      <div class="flex justify-between items-center bg-[#131b2e] rounded-lg px-3 py-2">
        <span class="text-slate-500">% FIU</span>
        <span id="tooltip-fiu" class="font-semibold font-['JetBrains_Mono'] text-cyan-400"></span>
      </div>
      <div class="flex justify-between items-center bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 rounded-lg px-3 py-3 border border-emerald-500/30">
        <span class="text-slate-300 font-medium">% DIU Final</span>
        <span id="tooltip-pdiu" class="font-bold text-xl font-['JetBrains_Mono']"></span>
      </div>
    </div>
  </div>

  <style is:global>
    .scrollbar-thin::-webkit-scrollbar { width: 4px; }
    .scrollbar-thin::-webkit-scrollbar-track { background: #131b2e; }
    .scrollbar-thin::-webkit-scrollbar-thumb { background: #334155; border-radius: 2px; }
    .leaflet-container { background: #0a0f1a; }
    .leaflet-control-attribution { display: none !important; }
    .leaflet-control-zoom { border: none !important; }
    .leaflet-control-zoom a { background: #131b2e !important; color: #94a3b8 !important; border: 1px solid #1e293b !important; }
    .leaflet-control-zoom a:hover { background: #1a2236 !important; }
    .leaflet-popup-content-wrapper { background: #0d1525 !important; border: 1px solid #1e293b !important; border-radius: 12px !important; color: #e2e8f0 !important; }
    .leaflet-popup-tip { background: #0d1525 !important; }
    .city-label { background: transparent !important; border: none !important; z-index: 1000 !important; }
    .city-label img { display: none !important; }
    .leaflet-marker-icon { z-index: 1000 !important; }
  </style>

  <script>
    const getColor = (porcentaje) => {
      if (porcentaje >= 90) return '#10b981';
      if (porcentaje >= 70) return '#22c55e';
      if (porcentaje >= 50) return '#eab308';
      if (porcentaje >= 30) return '#f97316';
      return '#dc2626';
    };

    const getHeatColor = (porcentaje) => {
      if (porcentaje >= 90) return { r: 16, g: 185, b: 129 };
      if (porcentaje >= 70) return { r: 34, g: 197, b: 94 };
      if (porcentaje >= 50) return { r: 234, g: 179, b: 8 };
      if (porcentaje >= 30) return { r: 249, g: 115, b: 22 };
      return { r: 220, g: 38, b: 38 };
    };

    let map;
    let geoJsonLayer;
    let labelsLayer;
    let usuariosData = [];
    let indicadorActual = 'DIU';
    let geoDataGlobal = null;
    let empresaActual = 'PEREIRA-CARTAGO';

    async function initMap() {
      map = L.map('map', {
        center: [4.6, -76.0],
        zoom: 9,
        zoomControl: true,
        minZoom: 7,
        maxZoom: 12
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '',
        maxZoom: 19
      }).addTo(map);

      const response = await fetch('/colombia-municipios.geojson');
      const geoData = await response.json();

      const empresaSelect = document.getElementById('select-empresa');
      empresaActual = empresaSelect.value;
      
      const usuariosRes = await fetch('/api/usuarios.json?empresa=' + empresaActual);
      usuariosData = await usuariosRes.json();

      let totalUsuarios = 0;
      let sumaDiu = 0;

      geoData.features.forEach(feature => {
        const nombreMpio = feature.properties.MPIO_CNMBR.toUpperCase()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
          .replace(/\s+/g, ' ').trim();
        
        const usuario = usuariosData.find(u => {
          const nombreDB = u.municipio.toUpperCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .replace(/\s+/g, ' ').trim();
          return nombreDB === nombreMpio;
        });

        if (usuario) {
          console.log('Matched:', feature.properties.MPIO_CNMBR, '=', usuario.municipio);
          feature.properties.usuario = usuario;
          feature.properties.dptoGeo = feature.properties.DPTO_CNMBR;
          totalUsuarios += usuario.total_usuarios;
          const prop = indicadorActual === 'DIU' ? 'porcentaje_diu' : 'porcentaje_fiu';
        
        sumaDiu += usuario[prop];
        }
      });

      const promedio = sumaDiu / usuariosData.length;
      document.getElementById('stat-total').textContent = totalUsuarios.toLocaleString();
      document.getElementById('stat-promedio').textContent = promedio.toFixed(1) + '%';
      document.getElementById('stat-municipios').textContent = usuariosData.length;
      document.getElementById('stat-cumplimiento').textContent = promedio >= 80 ? 'Bueno' : promedio >= 50 ? 'Regular' : 'Bajo';

      geoJsonLayer = L.geoJSON(geoData, {
        style: (feature) => {
          const usuario = feature.properties.usuario;
          if (!usuario) {
            return { fillColor: '#1e293b', weight: 0.5, color: '#334155', fillOpacity: 0.1 };
          }
          
          const color = getColor(usuario.porcentaje_diu);
          const opacity = 0.6 + (usuario.porcentaje_diu / 100) * 0.4;
          
          return {
            fillColor: color,
            weight: 2,
            opacity: 1,
            color: color,
            fillOpacity: opacity
          };
        },
        onEachFeature: (feature, layer) => {
          const usuario = feature.properties.usuario;
          if (usuario) {
            const heatColor = getHeatColor(usuario.porcentaje_diu);
            const gradientStyle = `
              background: radial-gradient(circle at center, 
                rgba(${heatColor.r}, ${heatColor.g}, ${heatColor.b}, 0.8) 0%, 
                rgba(${heatColor.r}, ${heatColor.g}, ${heatColor.b}, 0.4) 50%, 
                rgba(${heatColor.r}, ${heatColor.g}, ${heatColor.b}, 0.1) 100%);
            `;
            layer.setStyle({ fillColor: getColor(usuario.porcentaje_diu) });
            
            layer.on('mouseover', (e) => {
              layer.setStyle({ 
                weight: 4, 
                fillOpacity: 0.95,
                color: '#ffffff'
              });
              const tooltip = document.getElementById('tooltip');
              const bounds = e.containerPoint;
              tooltip.style.left = bounds.x + 20 + 'px';
              tooltip.style.top = bounds.y - 80 + 'px';
              tooltip.classList.remove('hidden');
              
              document.getElementById('tooltip-nombre').textContent = feature.properties.MPIO_CNMBR;
              document.getElementById('tooltip-total').textContent = usuario.total_usuarios.toLocaleString();
              document.getElementById('tooltip-diu').textContent = usuario.cumplen_diu.toLocaleString();
              document.getElementById('tooltip-fiu').textContent = usuario.porcentaje_fiu + '%';
              document.getElementById('tooltip-pdiu').textContent = usuario.porcentaje_diu + '%';
              document.getElementById('tooltip-pdiu').style.color = getColor(usuario.porcentaje_diu);
            });

            layer.on('mouseout', () => {
              const color = getColor(usuario.porcentaje_diu);
              layer.setStyle({ 
                weight: 2, 
                fillOpacity: 0.6 + (usuario.porcentaje_diu / 100) * 0.4,
                color: color
              });
              document.getElementById('tooltip').classList.add('hidden');
            });
          }
        }
      }).addTo(map);

      geoDataGlobal = geoData;
      labelsLayer = L.layerGroup().addTo(map);
      
      geoData.features.forEach(feature => {
        const usuario = feature.properties.usuario;
        if (usuario) {
          let allCoords = [];
          
          if (feature.geometry.type === 'Polygon') {
            allCoords = feature.geometry.coordinates[0];
          } else if (feature.geometry.type === 'MultiPolygon') {
            feature.geometry.coordinates.forEach(polygon => {
              allCoords = allCoords.concat(polygon[0]);
            });
          }
          
          if (allCoords.length === 0) return;
          
          let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
          allCoords.forEach(c => {
            minX = Math.min(minX, c[0]);
            minY = Math.min(minY, c[1]);
            maxX = Math.max(maxX, c[0]);
            maxY = Math.max(maxY, c[1]);
          });
          
          const centerLng = (minX + maxX) / 2;
          const centerLat = (minY + maxY) / 2;
          const valorLabel = usuario[prop];
          const labelColor = getColor(valorLabel);
          
          const labelIcon = L.divIcon({
            className: 'city-label',
            html: `<div style="
              background: rgba(13, 21, 37, 0.9);
              border: 1.5px solid ${labelColor};
              border-radius: 4px;
              padding: 2px 8px;
              font-family: 'Outfit', sans-serif;
              font-size: 10px;
              font-weight: 700;
              color: ${labelColor};
              white-space: nowrap;
              box-shadow: 0 0 12px ${labelColor}60, 0 2px 4px rgba(0,0,0,0.5);
              backdrop-filter: blur(4px);
              z-index: 9999;
              position: relative;
            ">${feature.properties.MPIO_CNMBR} ${valorLabel}%</div>`,
            iconSize: [100, 24],
            iconAnchor: [50, 12]
          });
          
          L.marker([centerLat, centerLng], { icon: labelIcon }).addTo(labelsLayer);
        }
      });

      const listaDiv = document.getElementById('lista-municipios');
      usuariosData.sort((a, b) => b[prop] - a[prop]).forEach(u => {
        const valorLista = u[prop];
        const div = document.createElement('div');
        div.className = 'flex justify-between items-center p-3 rounded-lg hover:bg-[#131b2e] cursor-pointer transition-all border border-transparent hover:border-[#1e293b] group';
        div.innerHTML = `
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full" style="background: ${getColor(valorLista)}; box-shadow: 0 0 8px ${getColor(valorLista)};"></div>
            <span class="text-sm text-slate-300 group-hover:text-white">${u.municipio}</span>
          </div>
          <span class="font-bold font-['JetBrains_Mono'] text-sm" style="color: ${getColor(valorLista)}">${valorLista}%</span>
        `;
        div.onclick = () => {
          const feature = geoData.features.find(f => {
            const nombreMpio = f.properties.MPIO_CNMBR.toUpperCase()
              .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            const nombreDB = u.municipio.toUpperCase()
              .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            return nombreDB === nombreMpio || nombreDB.includes(nombreMpio) || nombreMpio.includes(nombreDB);
          });
          if (feature) {
            const layer = geoJsonLayer.getLayers().find(l => l.feature === feature);
            if (layer) {
              map.fitBounds(layer.getBounds(), { padding: [50, 50] });
              map.setZoom(10);
            }
          }
        };
        listaDiv.appendChild(div);
      });
    }

    window.showPanel = function(panel) {
      const btnLeyenda = document.getElementById('btn-leyenda');
      const btnMunicipios = document.getElementById('btn-municipios');
      const panelLeyenda = document.getElementById('panel-leyenda');
      const panelMunicipios = document.getElementById('panel-municipios');
      
      if (panel === 'leyenda') {
        btnLeyenda.className = 'flex-1 py-2 px-4 rounded-lg text-sm font-semibold transition-all bg-emerald-500/20 text-emerald-400 border border-emerald-500/30';
        btnMunicipios.className = 'flex-1 py-2 px-4 rounded-lg text-sm font-semibold transition-all bg-[#131b2e] text-slate-400 border border-[#1e293b]';
        panelLeyenda.classList.remove('hidden');
        panelMunicipios.classList.add('hidden');
      } else {
        btnMunicipios.className = 'flex-1 py-2 px-4 rounded-lg text-sm font-semibold transition-all bg-emerald-500/20 text-emerald-400 border border-emerald-500/30';
        btnLeyenda.className = 'flex-1 py-2 px-4 rounded-lg text-sm font-semibold transition-all bg-[#131b2e] text-slate-400 border border-[#1e293b]';
        panelMunicipios.classList.remove('hidden');
        panelLeyenda.classList.add('hidden');
      }
    };

    window.cambiarIndicador = function(indicador) {
      indicadorActual = indicador;
      
      const btnDiu = document.getElementById('btn-diu');
      const btnFiu = document.getElementById('btn-fiu');
      const labelIndicador = document.getElementById('label-indicador');
      
      if (indicador === 'DIU') {
        btnDiu.className = 'px-3 py-1.5 rounded-md text-xs font-semibold transition-all bg-emerald-500/20 text-emerald-400';
        btnFiu.className = 'px-3 py-1.5 rounded-md text-xs font-semibold transition-all text-slate-400 hover:text-white';
      } else {
        btnFiu.className = 'px-3 py-1.5 rounded-md text-xs font-semibold transition-all bg-emerald-500/20 text-emerald-400';
        btnDiu.className = 'px-3 py-1.5 rounded-md text-xs font-semibold transition-all text-slate-400 hover:text-white';
      }
      labelIndicador.textContent = indicador;
      
      document.getElementById('titulo-mapa').textContent = 'Mapa de Cumplimiento ' + indicador;
      
      const prop = indicador === 'DIU' ? 'porcentaje_diu' : 'porcentaje_fiu';
      const cumpleProp = indicador === 'DIU' ? 'cumplen_diu' : 'cumplen_fiu';
      
      let totalUsuarios = 0;
      let suma = 0;
      
      if (geoJsonLayer) {
        geoJsonLayer.eachLayer(layer => {
          const usuario = layer.feature.properties.usuario;
          if (usuario) {
            const valor = usuario[prop];
            const color = getColor(valor);
            const opacity = 0.6 + (valor / 100) * 0.4;
            layer.setStyle({
              fillColor: color,
              weight: 2,
              opacity: 1,
              color: color,
              fillOpacity: opacity
            });
            totalUsuarios += usuario.total_usuarios;
            suma += valor;
          }
        });
      }
      
      const promedio = suma / usuariosData.length;
      document.getElementById('stat-total').textContent = totalUsuarios.toLocaleString();
      document.getElementById('stat-promedio').textContent = promedio.toFixed(1) + '%';
      document.getElementById('stat-cumplimiento').textContent = promedio >= 80 ? 'Bueno' : promedio >= 50 ? 'Regular' : 'Bajo';
      
      if (labelsLayer) {
        labelsLayer.clearLayers();
        geoDataGlobal.features.forEach(feature => {
          const usuario = feature.properties.usuario;
          if (usuario) {
            let allCoords = [];
            if (feature.geometry.type === 'Polygon') {
              allCoords = feature.geometry.coordinates[0];
            } else if (feature.geometry.type === 'MultiPolygon') {
              feature.geometry.coordinates.forEach(polygon => {
                allCoords = allCoords.concat(polygon[0]);
              });
            }
            if (allCoords.length === 0) return;
            
            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            allCoords.forEach(c => {
              minX = Math.min(minX, c[0]);
              minY = Math.min(minY, c[1]);
              maxX = Math.max(maxX, c[0]);
              maxY = Math.max(maxY, c[1]);
            });
            
            const centerLng = (minX + maxX) / 2;
            const centerLat = (minY + maxY) / 2;
            const valor = usuario[prop];
            const labelColor = getColor(valor);
            
            const labelIcon = L.divIcon({
              className: 'city-label',
              html: `<div style="
                background: rgba(13, 21, 37, 0.9);
                border: 1.5px solid ${labelColor};
                border-radius: 4px;
                padding: 2px 8px;
                font-family: 'Outfit', sans-serif;
                font-size: 10px;
                font-weight: 700;
                color: ${labelColor};
                white-space: nowrap;
                box-shadow: 0 0 12px ${labelColor}60, 0 2px 4px rgba(0,0,0,0.5);
                backdrop-filter: blur(4px);
                z-index: 9999;
                position: relative;
              ">${feature.properties.MPIO_CNMBR} ${valor}%</div>`,
              iconSize: [100, 24],
              iconAnchor: [50, 12]
            });
            
            L.marker([centerLat, centerLng], { icon: labelIcon }).addTo(labelsLayer);
          }
        });
      }
      
      const listaDiv = document.getElementById('lista-municipios');
      listaDiv.innerHTML = '';
      usuariosData.sort((a, b) => b[prop] - a[prop]).forEach(u => {
        const valor = u[prop];
        const div = document.createElement('div');
        div.className = 'flex justify-between items-center p-3 rounded-lg hover:bg-[#131b2e] cursor-pointer transition-all border border-transparent hover:border-[#1e293b] group';
        div.innerHTML = `
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full" style="background: ${getColor(valor)}; box-shadow: 0 0 8px ${getColor(valor)};"></div>
            <span class="text-sm text-slate-300 group-hover:text-white">${u.municipio}</span>
          </div>
          <span class="font-bold font-['JetBrains_Mono'] text-sm" style="color: ${getColor(valor)}">${valor}%</span>
        `;
        listaDiv.appendChild(div);
      });
    };

    window.cambiarEmpresa = async function(empresa) {
      empresaActual = empresa;
      
      const usuariosRes = await fetch('/api/usuarios.json?empresa=' + empresa);
      usuariosData = await usuariosRes.json();
      
      if (geoJsonLayer) {
        geoJsonLayer.clearLayers();
      }
      if (labelsLayer) {
        labelsLayer.clearLayers();
      }
      
      const prop = indicadorActual === 'DIU' ? 'porcentaje_diu' : 'porcentaje_fiu';
      
      let totalUsuarios = 0;
      let suma = 0;
      
      geoDataGlobal.features.forEach(feature => {
        const nombreMpio = feature.properties.MPIO_CNMBR.toUpperCase()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
          .replace(/\s+/g, ' ').trim();
        
        const usuario = usuariosData.find(u => {
          const nombreDB = u.municipio.toUpperCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .replace(/\s+/g, ' ').trim();
          return nombreDB === nombreMpio;
        });

        if (usuario) {
          feature.properties.usuario = usuario;
          totalUsuarios += usuario.total_usuarios;
          suma += usuario[prop];
        } else {
          delete feature.properties.usuario;
        }
      });
      
      geoJsonLayer = L.geoJSON(geoDataGlobal, {
        style: (feature) => {
          const usuario = feature.properties.usuario;
          if (!usuario) {
            return { fillColor: '#1e293b', weight: 0.5, color: '#334155', fillOpacity: 0.1 };
          }
          
          const valor = usuario[prop];
          const color = getColor(valor);
          const opacity = 0.6 + (valor / 100) * 0.4;
          
          return {
            fillColor: color,
            weight: 2,
            opacity: 1,
            color: color,
            fillOpacity: opacity
          };
        },
        onEachFeature: (feature, layer) => {
          const usuario = feature.properties.usuario;
          if (usuario) {
            layer.on('mouseover', (e) => {
              layer.setStyle({ 
                weight: 4, 
                fillOpacity: 0.95,
                color: '#ffffff'
              });
              const tooltip = document.getElementById('tooltip');
              const bounds = e.containerPoint;
              tooltip.style.left = bounds.x + 20 + 'px';
              tooltip.style.top = bounds.y - 80 + 'px';
              tooltip.classList.remove('hidden');
              
              const valor = usuario[prop];
              document.getElementById('tooltip-nombre').textContent = feature.properties.MPIO_CNMBR;
              document.getElementById('tooltip-total').textContent = usuario.total_usuarios.toLocaleString();
              document.getElementById('tooltip-diu').textContent = indicadorActual === 'DIU' ? usuario.cumplen_diu.toLocaleString() : usuario.cumplen_fiu.toLocaleString();
              document.getElementById('tooltip-fiu').textContent = usuario.porcentaje_fiu + '%';
              document.getElementById('tooltip-pdiu').textContent = valor + '%';
              document.getElementById('tooltip-pdiu').style.color = getColor(valor);
            });

            layer.on('mouseout', () => {
              const valor = usuario[prop];
              const color = getColor(valor);
              layer.setStyle({ 
                weight: 2, 
                fillOpacity: 0.6 + (valor / 100) * 0.4,
                color: color
              });
              document.getElementById('tooltip').classList.add('hidden');
            });
          }
        }
      }).addTo(map);
      
      geoDataGlobal.features.forEach(feature => {
        const usuario = feature.properties.usuario;
        if (usuario) {
          let allCoords = [];
          
          if (feature.geometry.type === 'Polygon') {
            allCoords = feature.geometry.coordinates[0];
          } else if (feature.geometry.type === 'MultiPolygon') {
            feature.geometry.coordinates.forEach(polygon => {
              allCoords = allCoords.concat(polygon[0]);
            });
          }
          
          if (allCoords.length === 0) return;
          
          let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
          allCoords.forEach(c => {
            minX = Math.min(minX, c[0]);
            minY = Math.min(minY, c[1]);
            maxX = Math.max(maxX, c[0]);
            maxY = Math.max(maxY, c[1]);
          });
          
          const centerLng = (minX + maxX) / 2;
          const centerLat = (minY + maxY) / 2;
          const valor = usuario[prop];
          const labelColor = getColor(valor);
          
          const labelIcon = L.divIcon({
            className: 'city-label',
            html: `<div style="
              background: rgba(13, 21, 37, 0.9);
              border: 1.5px solid ${labelColor};
              border-radius: 4px;
              padding: 2px 8px;
              font-family: 'Outfit', sans-serif;
              font-size: 10px;
              font-weight: 700;
              color: ${labelColor};
              white-space: nowrap;
              box-shadow: 0 0 12px ${labelColor}60, 0 2px 4px rgba(0,0,0,0.5);
              backdrop-filter: blur(4px);
              z-index: 9999;
              position: relative;
            ">${feature.properties.MPIO_CNMBR} ${valor}%</div>`,
            iconSize: [100, 24],
            iconAnchor: [50, 12]
          });
          
          L.marker([centerLat, centerLng], { icon: labelIcon }).addTo(labelsLayer);
        }
      });
      
      const promedio = suma / usuariosData.length;
      document.getElementById('stat-total').textContent = totalUsuarios.toLocaleString();
      document.getElementById('stat-promedio').textContent = promedio.toFixed(1) + '%';
      document.getElementById('stat-municipios').textContent = usuariosData.length;
      document.getElementById('stat-cumplimiento').textContent = promedio >= 80 ? 'Bueno' : promedio >= 50 ? 'Regular' : 'Bajo';
      
      const listaDiv = document.getElementById('lista-municipios');
      listaDiv.innerHTML = '';
      usuariosData.sort((a, b) => b[prop] - a[prop]).forEach(u => {
        const valor = u[prop];
        const div = document.createElement('div');
        div.className = 'flex justify-between items-center p-3 rounded-lg hover:bg-[#131b2e] cursor-pointer transition-all border border-transparent hover:border-[#1e293b] group';
        div.innerHTML = `
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full" style="background: ${getColor(valor)}; box-shadow: 0 0 8px ${getColor(valor)};"></div>
            <span class="text-sm text-slate-300 group-hover:text-white">${u.municipio}</span>
          </div>
          <span class="font-bold font-['JetBrains_Mono'] text-sm" style="color: ${getColor(valor)}">${valor}%</span>
        `;
        listaDiv.appendChild(div);
      });
      
      map.setView([4.5, -72.5], 6);
    };

    initMap();
  </script>
